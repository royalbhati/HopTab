# Cloudflare Pages headers
# Long-cache static assets; keep HTML fresh.
/*.png
  Cache-Control: public, max-age=31536000, immutable
/*.jpg
  Cache-Control: public, max-age=31536000, immutable
# Revalidate CSS/JS every load (cheap 304s via ETag) so changes are never
# stuck behind a long edge TTL. Bust intentionally with ?v= on the <link> too.
/styles.css
  Cache-Control: public, max-age=0, must-revalidate
/app.js
  Cache-Control: public, max-age=0, must-revalidate
/
  Cache-Control: public, max-age=0, must-revalidate
# Guide pages (clean-URL directories) — keep HTML fresh
/*/
  Cache-Control: public, max-age=0, must-revalidate
/sitemap.xml
  Cache-Control: public, max-age=3600
/robots.txt
  Cache-Control: public, max-age=3600
